# 9Pay SDK Configuration
# Copy this file to .env and fill in your actual credentials

# Merchant ID from 9Pay
NINEPAY_MERCHANT_ID=YOUR_MERCHANT_ID

# Secret Key for API authentication
NINEPAY_SECRET_KEY=YOUR_SECRET_KEY

# Checksum Key for signature verification
NINEPAY_CHECKSUM_KEY=YOUR_CHECKSUM_KEY

# Environment: SANDBOX or PRODUCTION
NINEPAY_ENV=SANDBOX

# Optional: Callback URL for webhooks
# NINEPAY_CALLBACK_URL=https://yoursite.com/payment/callback

# Optional: Return URL after payment
# NINEPAY_RETURN_URL=https://yoursite.com/payment/return

# Optional: Back URL when user cancels
# NINEPAY_BACK_URL=https://yoursite.com/payment/cancel
